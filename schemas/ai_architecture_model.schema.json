{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://py2kdm.local/schemas/ai_architecture_model.schema.json",
  "title": "py2kdm AI-enriched Architecture Model",
  "allOf": [
    {
      "$ref": "https://py2kdm.local/schemas/architecture_model.schema.json"
    },
    {
      "type": "object",
      "required": [
        "ai_enrichment"
      ],
      "additionalProperties": true,
      "properties": {
        "ai_enrichment": {
          "$ref": "https://py2kdm.local/schemas/ai_architecture_model.schema.json#/$defs/aiEnrichment"
        }
      }
    }
  ],
  "$defs": {
    "aiEnrichment": {
      "type": "object",
      "required": [
        "status",
        "source",
        "suggestions",
        "summary"
      ],
      "additionalProperties": true,
      "properties": {
        "status": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "suggestions": {
          "type": "array",
          "items": {
            "$ref": "https://py2kdm.local/schemas/ai_architecture_model.schema.json#/$defs/aiSuggestion"
          }
        },
        "summary": {
          "type": "object"
        }
      }
    },
    "aiSuggestion": {
      "type": "object",
      "required": [
        "id",
        "suggestion_type",
        "message",
        "status",
        "source"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "suggestion_type": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "status": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        },
        "affected_elements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "proposed_changes": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    }
  }
}
