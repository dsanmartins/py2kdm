<?xml version='1.0' encoding='UTF-8'?>
<kdm:Segment xmlns:xmi="http://www.omg.org/XMI" xmlns:kdm="http://www.omg.org/spec/KDM/20160201/kdm" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:code="http://www.omg.org/spec/KDM/20160201/code" xmlns:action="http://www.omg.org/spec/KDM/20160201/action" name="example_project" xmi:version="2.0">
  <model xsi:type="code:CodeModel" name="example_project_CodeModel">
    <codeElement xsi:type="code:CompilationUnit" name="app.py">
      <codeElement xsi:type="code:CallableUnit" name="main">
        <codeElement xsi:type="code:StorableUnit" name="service"/>
        <codeElement xsi:type="action:ActionElement" name="service.create_user" kind="method_call">
          <actionRelation xsi:type="action:Calls" to="//@model.0/@codeElement.0/@codeElement.1/@codeElement.0"/>
        </codeElement>
      </codeElement>
      <codeElement xsi:type="code:ClassUnit" name="UserService">
        <codeElement xsi:type="code:MethodUnit" name="create_user">
